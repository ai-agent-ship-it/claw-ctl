apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ .AgentName }}-sa
  namespace: agents
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ .AgentName }}-role
  namespace: agents
rules:
# ======== CRYSTAL WALL (ZERO KNOWLEDGE) ========
# Agent can create secrets but CANNOT read them
- apiGroups: [""]
  resources: ["secrets"]
  verbs: ["create", "update", "delete"]
# ======== APPLICATION MANAGEMENT ========
- apiGroups: ["", "apps", "networking.k8s.io", "batch"]
  resources: ["pods", "deployments", "services", "ingresses", "jobs", "cronjobs", "configmaps"]
  verbs: ["*"]
# ======== DATABASE (CNPG) ========
- apiGroups: ["postgresql.cnpg.io"]
  resources: ["clusters", "scheduledbackups"]
  verbs: ["*"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ .AgentName }}-rolebinding
  namespace: agents
subjects:
- kind: ServiceAccount
  name: {{ .AgentName }}-sa
  namespace: agents
roleRef:
  kind: Role
  name: {{ .AgentName }}-role
  apiGroup: rbac.authorization.k8s.io
