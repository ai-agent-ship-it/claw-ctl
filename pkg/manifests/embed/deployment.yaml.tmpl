apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .AgentName }}-gateway
  namespace: agents
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ .AgentName }}
  template:
    metadata:
      labels:
        app: {{ .AgentName }}
      annotations:
        claw-ctl/config-hash: "{{ .ConfigHash }}"
    spec:
      serviceAccountName: {{ .AgentName }}-sa
      initContainers:
        - name: config-resolver
          image: bhgedigital/envsubst:latest
          command: ["sh", "-c"]
          args:
            - |
              envsubst < /config-template/config.json > /resolved-config/config.json
              echo "Config resolved successfully"
          envFrom:
            - secretRef:
                name: {{ .AgentName }}-secret
          volumeMounts:
            - name: config-template
              mountPath: /config-template
            - name: resolved-config
              mountPath: /resolved-config
      containers:
        - name: picoclaw
          image: ghcr.io/ai-agent-ship-it/picoclaw:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 18790
          envFrom:
            - secretRef:
                name: {{ .AgentName }}-secret
          volumeMounts:
            - name: resolved-config
              mountPath: /root/.picoclaw/config.json
              subPath: config.json

            - name: workspace-data
              mountPath: /root/.picoclaw/workspace
            - name: workspace-files
              mountPath: /root/.picoclaw/workspace/SOUL.md
              subPath: SOUL.md
            - name: workspace-files
              mountPath: /root/.picoclaw/workspace/IDENTITY.md
              subPath: IDENTITY.md
            - name: workspace-files
              mountPath: /root/.picoclaw/workspace/USER.md
              subPath: USER.md
            - name: workspace-files
              mountPath: /root/.picoclaw/workspace/AGENT.md
              subPath: AGENT.md
            - name: workspace-files
              mountPath: /root/.picoclaw/workspace/ENVIRONMENT.md
              subPath: ENVIRONMENT.md
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
      volumes:
        - name: config-template
          configMap:
            name: {{ .AgentName }}-config
        - name: resolved-config
          emptyDir: {}
        - name: workspace-data
          persistentVolumeClaim:
            claimName: {{ .AgentName }}-workspace
        - name: workspace-files
          configMap:
            name: {{ .AgentName }}-workspace
